      "height": 50,
      "strokeColor": "#868e96",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roundness": { "type": 3 },
      "boundElements": [{"id": "arrow-observe", "type": "arrow"}]
    },
    {
      "id": "l1-label",
      "type": "text",
      "x": 65,
