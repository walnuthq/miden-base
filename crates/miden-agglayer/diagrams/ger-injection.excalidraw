      "height": -60,
      "strokeColor": "#868e96",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "points": [[0, 0], [0, -60]],
      "startBinding": {"elementId": "l1", "focus": 0, "gap": 5},
      "endBinding": {"elementId": "ger-mgr", "focus": 0, "gap": 5}
    },
    {
      "id": "observe-label",
      "type": "text",
      "x": 130,
      "y": 240,
      "width": 90,
