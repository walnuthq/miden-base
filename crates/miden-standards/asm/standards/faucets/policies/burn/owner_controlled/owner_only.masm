use miden::standards::access::ownable2step

# POLICY PROCEDURES
# ================================================================================================

#! Owner-only burn predicate.
#!
#! Inputs:  [ASSET_KEY, ASSET_VALUE]
#! Outputs: []
#!
#! Panics if:
#! - note sender is not owner.
#!
#! Invocation: dynexec
pub proc check_policy
    exec.ownable2step::assert_sender_is_owner
    # => [ASSET_KEY, ASSET_VALUE]

    dropw dropw
    # => []
end
