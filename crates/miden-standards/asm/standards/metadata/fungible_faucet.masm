    adv.push_mapval
    locaddr.0
    # => [locaddr.0, LOGO_URI_HASH, pad(16)]
    exec.pipe_to_memory
    # => [pad(16)]

    loc_loadw_le.0
    push.LOGO_URI_0_SLOT[0..2]
    exec.native_account::set_item dropw

    loc_loadw_le.4
    push.LOGO_URI_1_SLOT[0..2]
