pub proc is_logo_uri_mutable
    exec.is_logo_uri_mutable_inner
    # => [is_logo_uri_mutable, pad(16)]
    swap drop
    # => [is_logo_uri_mutable, pad(15)]
end

#! Returns 1 if external link is mutable, and 0 otherwise.
#!
#! Inputs:  [pad(16)]
#! Outputs: [is_external_link_mutable, pad(15)]
