    loc_loadw_le.8
    push.LOGO_URI_2_SLOT[0..2]
    exec.native_account::set_item dropw

    loc_loadw_le.12
    push.LOGO_URI_3_SLOT[0..2]
    exec.native_account::set_item dropw

    loc_loadw_le.16
    push.LOGO_URI_4_SLOT[0..2]
    exec.native_account::set_item dropw

    loc_loadw_le.20
    push.LOGO_URI_5_SLOT[0..2]
    exec.native_account::set_item dropw

    loc_loadw_le.24
    push.LOGO_URI_6_SLOT[0..2]
    exec.native_account::set_item dropw
end

